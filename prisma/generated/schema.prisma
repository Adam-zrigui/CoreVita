generator client {
  provider = "prisma-client-js"
  output   = "../prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  createdAt      DateTime        @default(now())
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  branding       Branding?
  members        Membership[]
  pendingInvites PendingInvite[]
  studies        Study[]
  subscription   Subscription?
}

model User {
  id                     String                  @id @default(cuid())
  name                   String?
  email                  String?                 @unique
  emailVerified          DateTime?
  image                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  accounts               Account[]
  memberships            Membership[]
  notificationPreference NotificationPreference?
  pendingInvites         PendingInvite[]
  reports                Report[]                @relation("ReportAuthor")
  sessions               Session[]
  Study                  Study[]
  shareTokens            ShareToken[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      String   @default("VIEWER")
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Study {
  id           String       @id @default(cuid())
  tenantId     String
  studyUid     String       @unique
  title        String?
  patientId    String?
  patientName  String?
  modality     String?
  slices       Int          @default(0)
  status       StudyStatus  @default(PENDING)
  reportedAt   DateTime?
  description  String?
  studyDate    String?
  createdAt    DateTime     @default(now())
  uploadedById String?
  visible      Boolean      @default(true)
  reports      Report[]
  series       Series[]
  shareTokens  ShareToken[]
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  User         User?        @relation(fields: [uploadedById], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([uploadedById])
}

model Series {
  id            String     @id @default(cuid())
  seriesUid     String
  modality      String?
  instanceCount Int        @default(0)
  studyId       String
  createdAt     DateTime   @default(now())
  seriesNumber  Int?
  instances     Instance[]
  study         Study      @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@unique([studyId, seriesUid])
}

model Instance {
  id             String   @id @default(cuid())
  sopInstanceUid String?
  instanceNumber Int?
  storageDriver  String   @default("b2")
  storageKey     String
  filePath       String?
  seriesId       String
  createdAt      DateTime @default(now())
  series         Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@index([seriesId])
  @@index([storageKey])
}

model Subscription {
  id                 String    @id @default(cuid())
  tenantId           String    @unique
  stripeId           String    @unique
  status             String    @default("incomplete")
  priceId            String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Report {
  id        String       @id @default(cuid())
  studyId   String
  authorId  String?
  status    ReportStatus @default(DRAFT)
  content   String?
  createdAt DateTime     @default(now())
  author    User?        @relation("ReportAuthor", fields: [authorId], references: [id])
  study     Study        @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@index([studyId])
  @@index([studyId, createdAt(sort: Desc)])
}

model ShareToken {
  id            String   @id @default(cuid())
  token         String   @unique
  studyId       String
  createdById   String?
  expiresAt     DateTime
  password      String?
  allowDownload Boolean  @default(false)
  createdAt     DateTime @default(now())
  study         Study    @relation(fields: [studyId], references: [id], onDelete: Cascade)
  createdBy     User?    @relation(fields: [createdById], references: [id])

  @@index([studyId])
  @@index([createdById])
  @@index([studyId, createdAt(sort: Desc)])
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  prefix     String
  hash       String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
}

model Branding {
  id           String  @id @default(cuid())
  tenantId     String  @unique
  logoUrl      String?
  primaryColor String?
  accentColor  String?
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  email     Boolean  @default(true)
  browser   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PendingInvite {
  id          String   @id @default(cuid())
  email       String
  tenantId    String
  invitedById String
  createdAt   DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy User   @relation(fields: [invitedById], references: [id])

  @@unique([email, tenantId])
  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  actorId   String
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
}

enum StudyStatus {
  PENDING
  READING
  REPORTED
}

enum ReportStatus {
  DRAFT
  FINAL
}
